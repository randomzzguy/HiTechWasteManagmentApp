# =============================================================
# Hi-Tech Waste Management - Environment Variables Example
# Copy this file to .env and fill in the actual values
# =============================================================

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
POSTGRES_PASSWORD=your_secure_postgres_password
DATABASE_URL=postgresql://hitech:your_secure_postgres_password@localhost:5432/hitech_waste
REDIS_URL=redis://localhost:6379

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_SYNC_POOL_SIZE=5
DB_SYNC_MAX_OVERFLOW=10

# ----------------------------------------------------------
# Milvus Vector Database
# ----------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ----------------------------------------------------------
# Ollama LLM
# ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ----------------------------------------------------------
# MQTT Broker
# ----------------------------------------------------------
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_GPS=fleet/gps/#

# ----------------------------------------------------------
# Authentication & Security
# ⚠️ CRITICAL: Change these values in production!
# Generate strong secrets using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------
JWT_SECRET=change-this-secret-key-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
NEXTAUTH_SECRET=change-this-nextauth-secret-minimum-32-characters
NEXTAUTH_URL=http://localhost:3000

# ----------------------------------------------------------
# CORS
# ⚠️ CRITICAL: Change from "*" to specific domains in production!
# Example: https://app.hitechwaste.com.my,https://admin.hitechwaste.com.my
# ----------------------------------------------------------
ALLOWED_ORIGINS=*

# ----------------------------------------------------------
# Application URLs
# ----------------------------------------------------------
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ----------------------------------------------------------
# PDF / Reports
# ----------------------------------------------------------
REPORT_OUTPUT_DIR=/app/generated_reports
CERTIFICATE_TEMPLATE_DIR=/app/templates/certificates

# ----------------------------------------------------------
# Email Notifications (optional)
# ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Hi-Tech Waste Management

# ----------------------------------------------------------
# WhatsApp Notifications (optional)
# ----------------------------------------------------------
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ----------------------------------------------------------
# MinIO / Object Storage
# ⚠️ CRITICAL: Change these credentials in production!
# ----------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ----------------------------------------------------------
# App Meta
# ----------------------------------------------------------
APP_TITLE=Hi-Tech Waste Management API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO

# ----------------------------------------------------------
# Sentry Error Tracking (optional)
# ----------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXCLUDE_PATHS=/health,/metrics,/docs,/openapi.json
