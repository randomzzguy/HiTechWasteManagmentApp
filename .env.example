# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://hitech:password@postgres:5432/hitech_waste
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────
# Milvus Vector Database
# ─────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ─────────────────────────────────────────────
# Ollama LLM
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ─────────────────────────────────────────────
# MQTT Broker
# ─────────────────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TOPIC_GPS=fleet/gps/#

# ─────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# or:
#   openssl rand -hex 32
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRE_MINUTES=60
NEXTAUTH_SECRET=change-this-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Environment & CORS
# ─────────────────────────────────────────────
# APP_ENV controls behaviour:
#   development — create_all_tables() runs on startup, debug logging enabled
#   production  — Alembic migrations only, CORS locked to ALLOWED_ORIGINS
APP_ENV=development

# Comma-separated list of allowed CORS origins.
# Use * for local development only.
# Production example: https://app.hitechwaste.com.my,https://admin.hitechwaste.com.my
ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─────────────────────────────────────────────
# PDF / Reports
# ─────────────────────────────────────────────
REPORT_OUTPUT_DIR=/app/generated_reports
CERTIFICATE_TEMPLATE_DIR=/app/templates/certificates

# ─────────────────────────────────────────────
# Email Notifications (optional)
# ─────────────────────────────────────────────
# Gmail: enable 2FA, then generate an App Password at
#   https://myaccount.google.com/apppasswords
# Use the 16-character app password as SMTP_PASSWORD (no spaces).
# Other providers: update SMTP_HOST/PORT accordingly.
#   Outlook/Office365: smtp.office365.com:587
#   SendGrid:          smtp.sendgrid.net:587  (user=apikey, password=<API_KEY>)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@hitechwaste.com.my
SMTP_PASSWORD=
SMTP_FROM_NAME=Hi-Tech Waste Management

# ─────────────────────────────────────────────
# WhatsApp Notifications (optional)
# ─────────────────────────────────────────────
# Uses the WhatsApp Business Cloud API (Meta).
# 1. Create a Meta Developer app at https://developers.facebook.com
# 2. Add the WhatsApp product and get a Phone Number ID
# 3. Generate a permanent System User token
# WHATSAPP_API_URL format:
#   https://graph.facebook.com/v18.0/<PHONE_NUMBER_ID>/messages
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ─────────────────────────────────────────────
# MinIO (Milvus dependency — object storage)
# ─────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=minio:9000
