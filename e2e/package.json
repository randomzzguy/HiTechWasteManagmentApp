{
  "name": "hitech-waste-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end API and UI tests for Hi-Tech Waste Management",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:api:core": "playwright test api/core-workflow.spec.ts --project=api",
    "test:api:ai": "playwright test api/ai-features.spec.ts --project=api",
    "test:api:compliance": "playwright test api/compliance.spec.ts --project=api",
    "test:api:fleet": "playwright test api/fleet.spec.ts --project=api",
    "test:api:esg": "playwright test api/esg.spec.ts --project=api",
    "test:ui": "playwright test tests/ui --project=chromium",
    "test:ui:all": "playwright test tests/ui --project=chromium --project=firefox --project=webkit",
    "test:ui:dashboard": "playwright test tests/ui/dashboard.spec.ts --project=chromium",
    "test:ui:jobs": "playwright test tests/ui/jobs.spec.ts --project=chromium",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:trace": "playwright test --trace on",
    "test:full": "playwright test --project=api && playwright test tests/ui --project=chromium",
    "report": "playwright show-report",
    "install:browsers": "playwright install",
    "install:deps": "playwright install-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
