# =============================================================
# Hi-Tech Waste Management — .gitignore
# =============================================================

# ─── Environment / Secrets ───────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ─── Node / Next.js ──────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
.vercel/
.netlify/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
*.tsbuildinfo

# ─── Docker ──────────────────────────────────────────────────
# Don't ignore docker-compose files — they're part of the project
# But ignore any local override files
docker-compose.override.yml

# ─── Certificates / SSL ──────────────────────────────────────
nginx/ssl/
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Database ────────────────────────────────────────────────
*.sql
*.dump
*.sqlite
*.db
backups/

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
*.pid

# ─── IDE / OS ────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ─── MinIO / Object Storage ──────────────────────────────────
minio_data/

# ─── Test / Coverage Reports ────────────────────────────────
htmlcov/
coverage/
.nyc_output/
test-results/
playwright-report/
*.lcov

# ─── Temporary Files ─────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
